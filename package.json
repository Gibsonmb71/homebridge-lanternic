{
  "name": "homebridge-lanternic",
  "displayName": "LanternIC",
  "type": "module",
  "version": "0.2.4",
  "description": "Homebridge plugin for BLE RGBIC/RGBWIC light strips controlled by the Magic Lantern app.",
  "author": "Gibson Bell",
  "license": "MIT",
  "homepage": "https://github.com/Gibsonmb71/homebridge-lanternic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gibsonmb71/homebridge-lanternic.git"
  },
  "bugs": {
    "url": "https://github.com/Gibsonmb71/homebridge-lanternic/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge-config-ui-x",
    "magic-lantern",
    "rgbic",
    "rgbwic",
    "ble",
    "bluetooth"
  ],
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "lanternic-calibrate": "tools/calibrate.mjs",
    "lanternic-explore": "tools/explore.mjs",
    "lanternic-scan": "tools/scan.mjs",
    "lanternic-send": "tools/send.mjs",
    "lanternic-send-sequence": "tools/send-sequence.mjs"
  },
  "files": [
    "config.schema.json",
    "dist",
    "LICENSE",
    "README.md",
    "tools/calibrate.mjs",
    "tools/calibrator",
    "tools/explore.mjs",
    "tools/scan.mjs",
    "tools/send.mjs",
    "tools/send-sequence.mjs"
  ],
  "engines": {
    "node": "^18.15.0 || ^20.7.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc -p tsconfig.build.json",
    "calibrate": "node tools/calibrate.mjs",
    "explore": "node tools/explore.mjs",
    "lint": "eslint . --max-warnings=0",
    "scan": "node tools/scan.mjs",
    "send": "node tools/send.mjs",
    "send-sequence": "node tools/send-sequence.mjs",
    "smoke:package": "node scripts/smoke-package.mjs",
    "test": "rimraf ./.test-dist && tsc -p tsconfig.test.json && node scripts/run-tests.mjs",
    "watch": "tsc --watch",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@stoprocent/noble": "^2.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stoprocent/bleno": "^0.12.5",
    "@types/node": "^18.19.130",
    "eslint": "^9.39.4",
    "homebridge": "^1.11.4",
    "rimraf": "^5.0.10",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.55.0"
  }
}
