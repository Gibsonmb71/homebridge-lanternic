{
  "name": "homebridge-lanternic",
  "displayName": "LanternIC",
  "type": "module",
  "version": "0.2.4",
  "description": "Homebridge plugin for BLE RGBIC/RGBWIC light strips controlled by the Magic Lantern app.",
  "author": "Gibson Bell",
  "license": "MIT",
  "homepage": "https://github.com/Gibsonmb71/homebridge-lanternic#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gibsonmb71/homebridge-lanternic.git"
  },
  "bugs": {
    "url": "https://github.com/Gibsonmb71/homebridge-lanternic/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "homebridge-config-ui-x",
    "magic-lantern",
    "rgbic",
    "rgbwic",
    "ble",
    "bluetooth"
  ],
  "main": "dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "bin": {
    "lanternic-calibrate": "dist/tools/calibrate.js",
    "lanternic-explore": "dist/tools/explore.js",
    "lanternic-scan": "dist/tools/scan.js",
    "lanternic-send": "dist/tools/send.js",
    "lanternic-send-sequence": "dist/tools/send-sequence.js"
  },
  "files": [
    "config.schema.json",
    "dist",
    "LICENSE",
    "README.md",
    "tools/calibrator"
  ],
  "engines": {
    "node": "^18.15.0 || ^20.7.0 || ^22.0.0 || ^24.0.0",
    "homebridge": "^1.8.0 || ^2.0.0"
  },
  "scripts": {
    "build": "rimraf ./dist && tsc -p tsconfig.build.json && tsc -p tools/calibrator/tsconfig.json",
    "calibrate": "tsx tools/calibrate.ts",
    "explore": "tsx tools/explore.ts",
    "lint": "eslint . --max-warnings=0",
    "scan": "tsx tools/scan.ts",
    "send": "tsx tools/send.ts",
    "send-sequence": "tsx tools/send-sequence.ts",
    "smoke:package": "tsx scripts/smoke-package.ts",
    "swift:build": "swift build --package-path swift/LanternICDaemon",
    "swift:test": "swift test --package-path swift/LanternICDaemon",
    "test": "rimraf ./.test-dist && tsc -p tsconfig.test.json && tsx scripts/run-tests.ts",
    "watch": "tsc --watch",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@stoprocent/noble": "^2.5.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@stoprocent/bleno": "^0.12.5",
    "@types/node": "^25.9.3",
    "eslint": "^9.39.4",
    "homebridge": "^1.11.4",
    "jiti": "^2.7.0",
    "rimraf": "^5.0.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "8.55.0"
  }
}
