{
  "pluginAlias": "LanternIC",
  "pluginType": "platform",
  "singular": true,
  "strictValidation": false,
  "schema": {
    "type": "object",
    "required": [
      "name"
    ],
    "additionalProperties": false,
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "LanternIC"
      },
      "setupMode": {
        "title": "Setup Mode",
        "type": "string",
        "default": "auto",
        "description": "Choose Auto Mode for first setup unless you already know your strip's Bluetooth address.",
        "oneOf": [
          {
            "title": "Auto Mode",
            "enum": [
              "auto"
            ]
          },
          {
            "title": "Manual Mode",
            "enum": [
              "manual"
            ]
          }
        ],
        "condition": {
          "functionBody": "return !model.devices || model.devices.length === 0;"
        }
      },
      "devices": {
        "title": "Light Strips",
        "type": "array",
        "buttonText": "Add Light Strip",
        "default": [],
        "description": "Use discovery logs or lanternic-scan to find Magic Lantern BLE device ids. On Linux this is usually the MAC address; on macOS it may be a long CoreBluetooth id.",
        "condition": {
          "functionBody": "return (model.devices && model.devices.length > 0) || model.setupMode === 'manual';"
        },
        "items": {
          "type": "object",
          "required": [
            "name",
            "address"
          ],
          "additionalProperties": false,
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "default": "LED Strip"
            },
            "address": {
              "title": "Bluetooth Address / Id",
              "type": "string",
              "description": "MAC address or Noble peripheral id. Colons are optional. Use the value printed as address= in LanternIC discovery logs.",
              "placeholder": "BE:16:70:00:08:2A"
            },
            "model": {
              "title": "Model",
              "type": "string",
              "default": "Magic Lantern RGBIC"
            },
            "manufacturer": {
              "title": "Manufacturer",
              "type": "string",
              "default": "Magic Lantern"
            },
            "colorOrder": {
              "title": "Color Order",
              "type": "string",
              "default": "rgb",
              "oneOf": [
                {
                  "title": "RGB",
                  "enum": [
                    "rgb"
                  ]
                },
                {
                  "title": "RBG",
                  "enum": [
                    "rbg"
                  ]
                },
                {
                  "title": "GRB",
                  "enum": [
                    "grb"
                  ]
                },
                {
                  "title": "GBR",
                  "enum": [
                    "gbr"
                  ]
                },
                {
                  "title": "BRG",
                  "enum": [
                    "brg"
                  ]
                },
                {
                  "title": "BGR",
                  "enum": [
                    "bgr"
                  ]
                }
              ]
            },
            "powerMode": {
              "title": "Power Mode",
              "type": "string",
              "default": "both",
              "description": "Both sends RGB black before the native off frame. This is the safest default for firmware that accepts RGB colors but ignores native power frames.",
              "oneOf": [
                {
                  "title": "Native + RGB Black Fallback",
                  "enum": [
                    "both"
                  ]
                },
                {
                  "title": "Native Power Frames Only",
                  "enum": [
                    "native"
                  ]
                },
                {
                  "title": "RGB Black Only",
                  "enum": [
                    "rgbBlack"
                  ]
                }
              ]
            },
            "brightnessMode": {
              "title": "Brightness Mode",
              "type": "string",
              "default": "rgb",
              "description": "RGB scaling dims by changing RGB values, which works on strips that ignore native brightness frames.",
              "oneOf": [
                {
                  "title": "RGB Scaling",
                  "enum": [
                    "rgb"
                  ]
                },
                {
                  "title": "Native Brightness Frame",
                  "enum": [
                    "native"
                  ]
                },
                {
                  "title": "Native + RGB Scaling",
                  "enum": [
                    "both"
                  ]
                }
              ]
            },
            "effects": {
              "title": "Effects",
              "type": "object",
              "additionalProperties": false,
              "description": "Optional HomeKit switch services for Magic Lantern animation effects.",
              "properties": {
                "enabled": {
                  "title": "Expose Effect Switches",
                  "type": "boolean",
                  "default": false,
                  "description": "Add HomeKit switches for Magic Lantern effects on this strip. Turning an effect switch off restores the normal light color by default."
                },
                "defaultSpeed": {
                  "title": "Default Effect Speed",
                  "type": "integer",
                  "default": 39,
                  "minimum": 0,
                  "maximum": 100,
                  "description": "Speed frame value sent before effect frames. 0 is slowest, 100 is fastest."
                },
                "restoreColorOnDisable": {
                  "title": "Restore Color When Effect Turns Off",
                  "type": "boolean",
                  "default": true,
                  "description": "When an active effect switch is turned off, send the saved HomeKit color and brightness back to the strip."
                },
                "items": {
                  "title": "Effect Switches",
                  "type": "array",
                  "buttonText": "Add Effect",
                  "default": [
                    {
                      "name": "AutoPlay",
                      "code": 0
                    },
                    {
                      "name": "Magic Back",
                      "code": 1
                    },
                    {
                      "name": "Yellow Marquee",
                      "code": 207
                    }
                  ],
                  "description": "Effect codes are the xx byte in 7e0503xx06ffff00ef. Codes may be decimal, so Yellow Marquee is 207 for hex CF.",
                  "items": {
                    "type": "object",
                    "required": [
                      "name",
                      "code"
                    ],
                    "additionalProperties": false,
                    "properties": {
                      "name": {
                        "title": "Name",
                        "type": "string",
                        "default": "Effect"
                      },
                      "code": {
                        "title": "Effect Code",
                        "type": "integer",
                        "default": 0,
                        "minimum": 0,
                        "maximum": 255,
                        "description": "Decimal value for the effect byte. For example hex CF is decimal 207."
                      },
                      "id": {
                        "title": "Stable Id",
                        "type": "string",
                        "description": "Optional stable HomeKit service id. Leave blank unless you are renaming or reordering effects and want to preserve existing HomeKit tiles."
                      },
                      "speed": {
                        "title": "Effect Speed Override",
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 100,
                        "description": "Optional speed override for this effect. Leave blank to use Default Effect Speed."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "discovery": {
        "title": "Discovery",
        "type": "object",
        "additionalProperties": false,
        "condition": {
          "functionBody": "return model.devices && model.devices.length > 0;"
        },
        "properties": {
          "enabled": {
            "title": "Log Discovered Candidate Devices",
            "type": "boolean",
            "default": true,
            "description": "Scan on Homebridge startup and print candidate devices plus copy/paste JSON snippets to the logs."
          },
          "autoAdd": {
            "title": "Auto-Add Discovered Devices",
            "type": "boolean",
            "default": false,
            "description": "Automatically create HomeKit accessories for matching discovered BLE devices. Leave off until your filters only match your strips."
          },
          "scanSeconds": {
            "title": "Scan Time",
            "type": "integer",
            "default": 15,
            "minimum": 3,
            "maximum": 120
          },
          "minRssi": {
            "title": "Minimum RSSI",
            "type": "integer",
            "default": -95,
            "minimum": -127,
            "maximum": 0,
            "description": "Ignore very weak candidates. Higher values are stricter; for example -70 only finds nearby devices."
          },
          "namePrefixes": {
            "title": "Candidate Name Prefixes",
            "type": "array",
            "default": [
              "Triones",
              "MELK",
              "ELK-BLEDOM",
              "LED",
              "OA"
            ],
            "items": {
              "type": "string"
            }
          },
          "serviceUuids": {
            "title": "Candidate Service UUIDs",
            "type": "array",
            "default": [
              "fff0"
            ],
            "description": "Also treat devices advertising these services as candidates.",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ble": {
        "title": "Bluetooth",
        "type": "object",
        "additionalProperties": false,
        "condition": {
          "functionBody": "return model.devices && model.devices.length > 0;"
        },
        "properties": {
          "binding": {
            "title": "Noble Binding",
            "type": "string",
            "default": "default",
            "description": "Default auto-selects macOS, Windows, or Linux HCI. Use Linux HCI when you need explicit HCI settings.",
            "oneOf": [
              {
                "title": "Default",
                "enum": [
                  "default"
                ]
              },
              {
                "title": "Linux HCI",
                "enum": [
                  "hci"
                ]
              },
              {
                "title": "macOS",
                "enum": [
                  "mac"
                ]
              },
              {
                "title": "Windows",
                "enum": [
                  "win"
                ]
              }
            ]
          },
          "hciDriver": {
            "title": "Linux HCI Driver",
            "type": "string",
            "default": "native",
            "description": "Native is the normal Linux/Raspberry Pi driver. USB/UART are for dedicated adapters.",
            "oneOf": [
              {
                "title": "Native",
                "enum": [
                  "native"
                ]
              },
              {
                "title": "Default",
                "enum": [
                  "default"
                ]
              },
              {
                "title": "USB",
                "enum": [
                  "usb"
                ]
              },
              {
                "title": "UART",
                "enum": [
                  "uart"
                ]
              }
            ]
          },
          "hciDeviceId": {
            "title": "Linux HCI Device Id",
            "type": "integer",
            "default": 0,
            "minimum": 0,
            "description": "For hci0 use 0, hci1 use 1, and so on."
          },
          "hciUserChannel": {
            "title": "Linux HCI User Channel",
            "type": "boolean",
            "default": false,
            "description": "Advanced Linux option. Usually leave off unless raw HCI permissions conflict with bluetoothd."
          },
          "hciExtended": {
            "title": "BLE 5 Extended Features",
            "type": "boolean",
            "description": "Optional advanced setting. Leave blank/default unless your adapter needs extended feature behavior forced."
          },
          "serviceUuid": {
            "title": "Service UUID",
            "type": "string",
            "default": "fff0"
          },
          "characteristicUuid": {
            "title": "Characteristic UUID",
            "type": "string",
            "default": "fff3"
          },
          "keepConnected": {
            "title": "Keep Connected",
            "type": "boolean",
            "default": false,
            "description": "Maintain a BLE connection and automatically reconnect after disconnects. Improves HomeKit responsiveness but may prevent the Magic Lantern app from connecting at the same time."
          },
          "connectTimeoutMs": {
            "title": "Connect Timeout",
            "type": "integer",
            "default": 15000,
            "minimum": 1000,
            "maximum": 60000
          },
          "scanTimeoutMs": {
            "title": "Scan Timeout",
            "type": "integer",
            "default": 15000,
            "minimum": 1000,
            "maximum": 120000
          },
          "writeTimeoutMs": {
            "title": "Write Timeout",
            "type": "integer",
            "default": 5000,
            "minimum": 500,
            "maximum": 60000
          },
          "retryAttempts": {
            "title": "Retry Attempts",
            "type": "integer",
            "default": 3,
            "minimum": 1,
            "maximum": 10
          },
          "retryDelayMs": {
            "title": "Retry Delay",
            "type": "integer",
            "default": 500,
            "minimum": 0,
            "maximum": 10000
          },
          "maxRetryDelayMs": {
            "title": "Max Retry Delay",
            "type": "integer",
            "default": 5000,
            "minimum": 0,
            "maximum": 60000
          },
          "reconnectDelayMs": {
            "title": "Reconnect Delay",
            "type": "integer",
            "default": 1000,
            "minimum": 0,
            "maximum": 60000
          },
          "maxReconnectDelayMs": {
            "title": "Max Reconnect Delay",
            "type": "integer",
            "default": 60000,
            "minimum": 1000,
            "maximum": 600000
          },
          "writeDelayMs": {
            "title": "Delay Between Writes",
            "type": "integer",
            "default": 120,
            "minimum": 0,
            "maximum": 5000
          },
          "idleDisconnectMs": {
            "title": "Idle Disconnect",
            "type": "integer",
            "default": 30000,
            "minimum": 0,
            "maximum": 600000
          },
          "writeMode": {
            "title": "Write Mode",
            "type": "string",
            "default": "auto",
            "oneOf": [
              {
                "title": "Auto",
                "enum": [
                  "auto"
                ]
              },
              {
                "title": "With Response",
                "enum": [
                  "withResponse"
                ]
              },
              {
                "title": "Without Response",
                "enum": [
                  "withoutResponse"
                ]
              }
            ]
          }
        }
      }
    }
  }
}
